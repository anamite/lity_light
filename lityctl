#!/usr/bin/env bash
# lityctl — start/stop/restart/status/logs for Lity.
# Usage: ./lityctl {start|stop|restart|status|logs|help}

set -u

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

PIDFILE="$ROOT/.lity.pid"
LOGDIR="$ROOT/logs"
LOGFILE="$LOGDIR/lity.log"
PYTHON="$ROOT/.venv/bin/python"
[ -x "$PYTHON" ] || PYTHON="$ROOT/.venv/Scripts/python.exe"  # Windows venv, if ever run there

PORT="$(grep -E '^\s*port:' config.yaml | head -1 | grep -oE '[0-9]+' || echo 8321)"

pid_alive() {
    [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

cmd_start() {
    if pid_alive; then
        echo "Lity is already running (pid $(cat "$PIDFILE"), http://localhost:$PORT)."
        return 0
    fi
    if [ ! -x "$PYTHON" ]; then
        echo "No venv found at .venv — run ./install.sh (or set up .venv) first." >&2
        return 1
    fi
    mkdir -p "$LOGDIR"
    # extra args (e.g. --voice / --no-voice) pass straight to `python -m lity`.
    # -u: unbuffered — otherwise Python buffers prints when stdout is a file
    # and the log stays empty until the buffer fills.
    nohup "$PYTHON" -u -m lity "$@" >> "$LOGFILE" 2>&1 &
    disown
    echo $! > "$PIDFILE"
    sleep 1
    if pid_alive; then
        echo "Lity started (pid $(cat "$PIDFILE")) -> http://localhost:$PORT"
        echo "Logs: ./lityctl logs"
    else
        echo "Lity failed to start — check $LOGFILE" >&2
        rm -f "$PIDFILE"
        tail -n 20 "$LOGFILE" 2>/dev/null
        return 1
    fi
}

cmd_stop() {
    if ! pid_alive; then
        echo "Lity is not running."
        rm -f "$PIDFILE"
        return 0
    fi
    pid="$(cat "$PIDFILE")"
    kill "$pid"
    for _ in $(seq 1 10); do
        pid_alive || break
        sleep 1
    done
    if pid_alive; then
        echo "Still up after 10s, forcing kill -9."
        kill -9 "$pid" 2>/dev/null
    fi
    rm -f "$PIDFILE"
    echo "Lity stopped."
}

cmd_restart() {
    cmd_stop
    cmd_start "$@"
}

cmd_devices() {
    if [ ! -x "$PYTHON" ]; then
        echo "No venv found at .venv — run ./install.sh first." >&2
        return 1
    fi
    "$PYTHON" -m lity --list-devices
}

cmd_setup() {
    if [ ! -x "$PYTHON" ]; then
        echo "No venv found at .venv — run ./install.sh first." >&2
        return 1
    fi
    "$PYTHON" -m lity.setup "$@"
}

cmd_fresh() {
    # Clear a thread's working context (default: Home thread 1). Nothing is
    # deleted — messages are marked collapsed and the rolling summary dropped;
    # history stays in the DB. Works with Lity running (SQLite WAL) or stopped.
    if [ ! -x "$PYTHON" ]; then
        echo "No venv found at .venv — run ./install.sh first." >&2
        return 1
    fi
    "$PYTHON" - "$@" <<'PYEOF'
import sqlite3, sys

import yaml

cfg = yaml.safe_load(open("config.yaml", encoding="utf-8")) or {}
db_path = str(cfg.get("database") or "./data/lity.db")
tid = int(sys.argv[1]) if len(sys.argv) > 1 else 1
try:
    con = sqlite3.connect(db_path, timeout=10)
except sqlite3.Error as e:
    sys.exit(f"Cannot open {db_path}: {e}")
try:
    n = con.execute("UPDATE messages SET collapsed=1 WHERE thread_id=? AND collapsed=0",
                    (tid,)).rowcount
    con.execute("DELETE FROM summaries WHERE thread_id=?", (tid,))
    con.commit()
finally:
    con.close()
print(f"Thread {tid}: context cleared — {n} messages folded away, summary dropped.")
print("History stays in the DB (searchable); long-term memory untouched.")
PYEOF
}

cmd_status() {
    if pid_alive; then
        pid="$(cat "$PIDFILE")"
        uptime="$(ps -o etime= -p "$pid" 2>/dev/null | xargs)"
        echo "Lity is running (pid $pid, up $uptime) -> http://localhost:$PORT"
    else
        echo "Lity is not running."
    fi
}

cmd_logs() {
    mkdir -p "$LOGDIR"
    touch "$LOGFILE"
    tail -n 50 -f "$LOGFILE"
}

cmd_help() {
    cat <<EOF
lityctl — manage the Lity process

Usage: ./lityctl <command>

Commands:
  start     Start Lity in the background (no-op if already running)
            Extra args pass through: ./lityctl start --voice
  stop      Stop Lity (graceful, then force after 10s)
  restart   stop, then start — use after pulling code or editing config.yaml/.env
  status    Show whether Lity is running and its pid/uptime
  logs      Tail the log file (Ctrl+C to stop watching, Lity keeps running)
  devices   List audio input/output devices (for config.yaml voice indices)
  setup     Interactive wizard: provider, models, API keys, voice — stores
            everything in config.yaml/.env automatically
  show      Current settings + which API keys are set (masked)
  get PATH  Read a config value            e.g. ./lityctl get models.main
  set PATH VALUE  Write a config value     e.g. ./lityctl set voice.enabled true
  key NAME [VALUE]  Set a .env key         e.g. ./lityctl key SPEECHMATICS_API_KEY
  fresh [THREAD]  Clear a conversation's working context (default: Home
            thread). Nothing is deleted — history stays searchable; the
            assistant just starts its next turn with a clean slate.
            (Or simply tell Lity: "start fresh".)
  help      Show this message

Pid file: $PIDFILE
Log file: $LOGFILE
EOF
}

CMD="${1:-help}"
shift 2>/dev/null || true
case "$CMD" in
    start)   cmd_start "$@" ;;
    stop)    cmd_stop ;;
    restart) cmd_restart "$@" ;;
    status)  cmd_status ;;
    logs)    cmd_logs ;;
    devices) cmd_devices ;;
    setup)   cmd_setup ;;
    show)    cmd_setup show ;;
    get)     cmd_setup get "$@" ;;
    set)     cmd_setup set "$@" ;;
    key)     cmd_setup key "$@" ;;
    fresh)   cmd_fresh "$@" ;;
    help|-h|--help) cmd_help ;;
    *) echo "Unknown command: $CMD" >&2; cmd_help; exit 1 ;;
esac
